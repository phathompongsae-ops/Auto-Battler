{
  "schemaVersion": 1,
  "id": "rule.secret_class_board_limit_v1",
  "scope": "player_board",
  "category": "secret_class",
  "maxDeployed": 1,
  "countsAcrossSecretClasses": true,
  "benchAllowed": true,
  "purchaseAllowedWhenLimitReached": true,
  "fusionAllowedWhenLimitReached": true,
  "enemyUnitsExcluded": true,
  "futureSecretClassesIncluded": true,
  "placementPolicy": {
    "rejectAdditionalSecretClass": true,
    "preserveSourcePositionOnReject": true,
    "preserveGoldAndInventoryOnReject": true,
    "allowReplacementAfterCurrentSecretLeavesBoard": true
  },
  "duplicatePolicy": {
    "sameSecretClassSecondCopyBlocked": true,
    "differentSecretClassBlockedWhileOneIsDeployed": true,
    "benchCopiesMayStillCombine": true,
    "maxStarSupportedByDemo1": 2
  },
  "messageKeys": {
    "genericLimit": "ui.secret_class.board_limit.generic",
    "duplicateClass": "ui.secret_class.board_limit.duplicate"
  },
  "runtimeOwner": "cc",
  "notes": [
    "This contract is generic and must not be hard-coded only for Ninja.",
    "Ninja, Black Dragon Knight, Sword Saint, and future Secret Classes share one deployed-unit limit.",
    "This file defines policy only and does not implement board placement Runtime."
  ]
}
